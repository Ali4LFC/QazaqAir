    "ssh_commands": {
      "value": "\n================================================================================\n                         SSH ACCESS COMMANDS\n================================================================================\n\nKEY FILE LOCATION:\n  ./dev-private-key.pem\n\nBASTION SSH (run from: terraform/labs/lab-complete):\n  ssh -i dev-private-key.pem ubuntu@52.59.203.244\n\nOR from project root:\n  ssh -i terraform/labs/lab-complete/dev-private-key.pem ubuntu@52.59.203.244\n\nPRIVATE EC2 VIA BASTION:\n  ssh -i dev-private-key.pem -J ubuntu@52.59.203.244 ubuntu@10.0.10.18\n\nPOWERSHELL (Windows):\n  ssh -i .\\dev-private-key.pem ubuntu@52.59.203.244\n\n================================================================================\n",
      "type": "string"
    },
