    "ssh_commands": {
      "value": "\n================================================================================\n                         SSH ACCESS COMMANDS\n================================================================================\n\nKEY FILE LOCATION:\n  ./dev-private-key.pem\n\nBASTION SSH (run from: terraform/labs/lab-complete):\n  ssh -i dev-private-key.pem ubuntu@3.72.45.63\n\nOR from project root:\n  ssh -i terraform/labs/lab-complete/dev-private-key.pem ubuntu@3.72.45.63\n\nPRIVATE EC2 VIA BASTION:\n  ssh -i dev-private-key.pem -J ubuntu@3.72.45.63 ubuntu@10.0.10.9\n\nPOWERSHELL (Windows):\n  ssh -i .\\dev-private-key.pem ubuntu@3.72.45.63\n\n================================================================================\n",
      "type": "string"
    },
