# Handle line endings automatically for files detected as text
# and perform CRLF to LF conversion on check-in.
* text=auto

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.sql binary

# Git configuration files should use LF
.gitattributes text eol=lf
.gitignore text eol=lf

# Ensure shell scripts always use LF line endings
*.sh text eol=lf

# Ensure Dockerfiles always use LF line endings
Dockerfile* text eol=lf

# Ensure configuration files mounted into containers use LF line endings
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.env text eol=lf
*.md text eol=lf
*.txt text eol=lf
